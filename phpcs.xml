<?xml version="1.0"?>
<ruleset name="FlavorLinkChecker">
    <description>PHPCS configuration for Flavor Link Checker</description>

    <file>./src</file>
    <file>./flavor-link-checker.php</file>
    <file>./uninstall.php</file>

    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>

    <config name="minimum_wp_version" value="6.9"/>
    <config name="testVersion" value="8.2-"/>

    <rule ref="WordPress">
        <!-- PSR-4 requires PascalCase filenames, not hyphenated-lowercase. -->
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>

        <!-- Deliberate choice: use slashes in hook names (like flc/scan/start) to group by feature. -->
        <exclude name="WordPress.NamingConventions.ValidHookName.UseUnderscores"/>

        <!-- DOMDocument properties like textContent and parentNode are camelCase in PHP. -->
        <exclude name="WordPress.NamingConventions.ValidVariableName.UsedPropertyNotSnakeCase"/>
    </rule>

    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="flavor-link-checker"/>
            </property>
        </properties>
    </rule>

    <!-- Exclude generated and vendor directories. -->
    <exclude-pattern>/vendor/*</exclude-pattern>
    <exclude-pattern>/node_modules/*</exclude-pattern>
    <exclude-pattern>/build/*</exclude-pattern>
</ruleset>
